# Server
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/skill-exchange

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRE=7d

# CORS
CLIENT_URL=http://localhost:3000

# Email (SMTP)
# Leave blank in development — emails will be printed to the console instead.
# For Gmail: use an App Password (not your account password).
# For testing: sign up at https://mailtrap.io and paste the SMTP credentials below.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_mailtrap_username
EMAIL_PASS=your_mailtrap_password
EMAIL_FROM=noreply@skill-exchange.com
