{
  "info": {
    "name": "Session Credit Rating Flow",
    "_postman_id": "8f4a4fb5-f4ee-4876-998d-ea4a315df9f4",
    "description": "End-to-end requests for session request, acceptance, completion, credit history, and ratings.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Register Learner",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"learner1@test.com\",\n  \"password\": \"Password123\",\n  \"firstName\": \"Learner\",\n  \"lastName\": \"One\",\n  \"role\": \"LEARNER\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register learner success', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.environment.set('learnerToken', json.data.accessToken);",
              "pm.environment.set('learnerId', json.data.user.userId);"
            ]
          }
        }
      ]
    },
    {
      "name": "2) Register Teacher",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"teacher1@test.com\",\n  \"password\": \"Password123\",\n  \"firstName\": \"Teacher\",\n  \"lastName\": \"One\",\n  \"role\": \"MENTOR\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register teacher success', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.environment.set('teacherToken', json.data.accessToken);",
              "pm.environment.set('teacherId', json.data.user.userId);"
            ]
          }
        }
      ]
    },
    {
      "name": "3) Request Session (Learner)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{learnerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"teacherId\": \"{{teacherId}}\",\n  \"skill\": \"Node.js\",\n  \"duration\": 2,\n  \"date\": \"2026-06-20T10:00:00.000Z\",\n  \"message\": \"Need help with backend architecture\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessions/request",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "sessions",
            "request"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Session requested', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.environment.set('sessionId', json.data.sessionId);"
            ]
          }
        }
      ]
    },
    {
      "name": "4) List Teacher Pending Sessions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teacherToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessions?role=teacher&status=pending",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "sessions"
          ],
          "query": [
            {
              "key": "role",
              "value": "teacher"
            },
            {
              "key": "status",
              "value": "pending"
            }
          ]
        }
      }
    },
    {
      "name": "5) Accept Session (Teacher)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teacherToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/accept",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "sessions",
            "{{sessionId}}",
            "accept"
          ]
        }
      }
    },
    {
      "name": "6) Complete Session (Teacher)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teacherToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/complete",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "sessions",
            "{{sessionId}}",
            "complete"
          ]
        }
      }
    },
    {
      "name": "7) Learner Credit History",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{learnerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/credits/history",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "credits",
            "history"
          ]
        }
      }
    },
    {
      "name": "8) Teacher Credit History",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teacherToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/credits/history",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "credits",
            "history"
          ]
        }
      }
    },
    {
      "name": "9) Submit Rating (Learner -> Teacher)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{learnerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"toUserId\": \"{{teacherId}}\",\n  \"score\": 5,\n  \"comment\": \"Great session\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/ratings",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "ratings"
          ]
        }
      }
    },
    {
      "name": "10) Get Teacher Ratings",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{learnerToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/{{teacherId}}/ratings",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "{{teacherId}}",
            "ratings"
          ]
        }
      }
    },
    {
      "name": "11) Negative - Complete Session Twice",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teacherToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/complete",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "sessions",
            "{{sessionId}}",
            "complete"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Second completion should fail with 409', function () {",
              "  pm.response.to.have.status(409);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "12) Negative - Duplicate Rating",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{learnerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"toUserId\": \"{{teacherId}}\",\n  \"score\": 4,\n  \"comment\": \"Trying duplicate\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/ratings",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "ratings"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Duplicate rating should fail with 409', function () {",
              "  pm.response.to.have.status(409);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "13) Negative - Invalid Sessions Filters",
      "item": [
        {
          "name": "Invalid Role Filter",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{learnerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions?role=owner",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "sessions"
              ],
              "query": [
                {
                  "key": "role",
                  "value": "owner"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid role should fail with 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid Status Filter",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{learnerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions?status=archived",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "sessions"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "archived"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid status should fail with 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
