{
  "info": {
    "name": "Admin RBAC User Management",
    "_postman_id": "0d2617f0-a2fd-4f08-b75f-46e3493ebee0",
    "description": "Admin-only user management endpoints with positive and negative RBAC checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Register Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-admin-bootstrap-secret",
            "value": "{{adminBootstrapSecret}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin1@test.com\",\n  \"password\": \"Password123\",\n  \"firstName\": \"Super\",\n  \"lastName\": \"Admin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register-admin",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register-admin"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register admin success', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.environment.set('adminToken', json.data.accessToken);",
              "pm.environment.set('adminId', json.data.user.userId);"
            ]
          }
        }
      ]
    },
    {
      "name": "2) Register Normal User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"normal1@test.com\",\n  \"password\": \"Password123\",\n  \"firstName\": \"Normal\",\n  \"lastName\": \"User\",\n  \"role\": \"LEARNER\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register normal user success', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.environment.set('userToken', json.data.accessToken);",
              "pm.environment.set('userId', json.data.user.userId);",
              "pm.environment.set('targetUserId', json.data.user.userId);"
            ]
          }
        }
      ]
    },
    {
      "name": "3) Negative RBAC - Normal User Cannot List Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/users?page=1&limit=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Normal user should get 403', function () {",
              "  pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4) Admin List All Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/users?page=1&limit=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Admin list users success', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5) Admin Get Single User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/users/{{targetUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users",
            "{{targetUserId}}"
          ]
        }
      }
    },
    {
      "name": "6) Admin Update User",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Renamed By Admin\",\n  \"email\": \"normal1-updated@test.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/users/{{targetUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users",
            "{{targetUserId}}"
          ]
        }
      }
    },
    {
      "name": "7) Admin Promote User",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/users/{{targetUserId}}/role",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users",
            "{{targetUserId}}",
            "role"
          ]
        }
      }
    },
    {
      "name": "8) Admin Demote User",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"user\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/users/{{targetUserId}}/role",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users",
            "{{targetUserId}}",
            "role"
          ]
        }
      }
    },
    {
      "name": "9) Negative - Admin Self Delete Blocked",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/users/{{adminId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users",
            "{{adminId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Self delete should fail with 400', function () {",
              "  pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "10) Admin Delete Target User",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/users/{{targetUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "users",
            "{{targetUserId}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "adminBootstrapSecret",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "adminId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "targetUserId",
      "value": ""
    }
  ]
}
